# ThinQ Workspace Sentinel — 로컬 개발용 환경 변수 예시
#
# 사용:
#   cp .env.example .env
#   docker compose -f infra/docker-compose.dev.yml up -d
#
# 주의:
#   .env 파일은 절대 git commit 금지 (CI secret-scan 잡이 차단)
#   실제 운영 키는 zln02(박진영) 에게 별도 채널로 받기

# ─── DB / Cache (docker-compose.dev.yml 과 일치) ───
DATABASE_URL=postgresql://sentinel:dev_local_password@localhost:55432/sentinel_dev
REDIS_URL=redis://localhost:56379/0

# ─── API ───
API_PORT=8003
API_HOST=0.0.0.0
LOG_LEVEL=INFO

# ─── Frontend (frontend/.env.local 도 동일하게) ───
NEXT_PUBLIC_API_BASE_URL=http://localhost:8003
NEXT_PUBLIC_SSE_URL=http://localhost:8003/api/v1/stream
# 데모 로그인 PW. 미설정 시 코드 폴백("1234"). 배포 시 반드시 설정.
NEXT_PUBLIC_DEMO_PW=1234

# ─── UIS 외부신호 (read-only) — W3 진입 후 사용 ───
# UIS_DATABASE_URL=postgresql://uis_reader:CHANGE_ME@<vm-ip>:5432/urban_immune
UIS_DATABASE_URL=

# ─── ThinQ SDK (Mock 모드가 기본 — 실 SDK는 W4 이후) ───
THINQ_MODE=mock
# THINQ_CLIENT_ID=
# THINQ_CLIENT_SECRET=

# ─── 실가전 어댑터 (미설정 시 각각 graceful 비활성) ───
# 코웨이 IoCare 공기청정기
# COWAY_USERNAME=
# COWAY_PASSWORD=
# 삼성 SmartThings 에어컨 — 토큰: https://account.smartthings.com/tokens
#   (천장형이 SmartThings 등록돼 있어야 함. device_id 비우면 자동탐색)
# SMARTTHINGS_TOKEN=
# SMARTTHINGS_AC_DEVICE_ID=

# ─── 시뮬레이션 ───
SIM_DEFAULT_SCENARIO=autumn_covid
SIM_DEFAULT_SPEED=60

# ─── 제어 API 인증 (운영 필수, 미설정 시 무인증) ───
# SENTINEL_API_KEY=
