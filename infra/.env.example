# ThinQ Workspace Sentinel · 환경 변수 템플릿
# 실제 값으로 채워서 프로젝트 루트의 .env 로 복사
# 절대 git commit 금지

# === DB (UIS 공유 TimescaleDB) ===
POSTGRES_PASSWORD=__변경__

# === LG ThinQ Business API ===
THINQ_CLIENT_ID=__변경__
THINQ_CLIENT_SECRET=__변경__
THINQ_REGION=KR

# === 외부 신호 API ===
KOWAS_API_KEY=__변경__
NAVER_DATALAB_KEY=__변경__
NAVER_DATALAB_SECRET=__변경__

# === Slack 알림 ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/__변경__
SLACK_DEFAULT_CHANNEL=#sentinel-alerts

# === Supabase (옵션) ===
SUPABASE_URL=
SUPABASE_KEY=

# === Grafana ===
GRAFANA_PASSWORD=__변경__

# === Claude API (Phase 2) ===
ANTHROPIC_API_KEY=

# === Sentry (옵션) ===
SENTRY_DSN=
